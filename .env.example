# Database
DATABASE_URL=sqlite:///./data/relationship_training.db

# API
API_HOST=0.0.0.0
API_PORT=8000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Log
LOG_LEVEL=INFO

# DeepSeek AI
# 不要把真实 token 提交到 Git；复制本文件为 .env 后在本机填写。
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_MODE=openai
DEEPSEEK_CHAT_PATH=/chat/completions
DEEPSEEK_TIMEOUT=60
DEEPSEEK_LIVE_PROBE_ENABLED=false
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_THINKING_ENABLED=true
